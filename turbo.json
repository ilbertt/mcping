{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "release": {
      "dependsOn": ["build"],
      "outputs": ["release/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "check:types": {
      "dependsOn": ["^check:types"]
    }
  }
}
